#!/bin/bash
# =============================================================
# Tomcat 환경 변수 설정 (Ansible 관리 - 직접 수정 금지)
# 호스트: {{ inventory_hostname }} | 환경: {{ environment }}
#
# 이 파일은 catalina.sh가 시작될 때 자동으로 소싱(source)됨
# 모든 JVM 옵션과 환경 변수를 여기서 중앙 관리
# =============================================================

# -------------------------------------------------------
# [Java 홈 디렉토리]
# 어느 JDK를 사용할지 명시 (시스템 기본 Java와 다른 버전 사용 시 중요)
# -------------------------------------------------------
export JAVA_HOME="{{ tomcat_java_home }}"
export JRE_HOME="${JAVA_HOME}"

# -------------------------------------------------------
# [CATALINA_HOME vs CATALINA_BASE]
# CATALINA_HOME: Tomcat 바이너리(bin/, lib/) 위치
# CATALINA_BASE: 설정(conf/), 로그(logs/), 웹앱(webapps/) 위치
# 한 서버에 여러 Tomcat 인스턴스를 띄울 때 CATALINA_BASE를 다르게 설정
# -------------------------------------------------------
export CATALINA_HOME="{{ tomcat_symlink }}"
export CATALINA_BASE="{{ tomcat_symlink }}"

# -------------------------------------------------------
# [PID 파일]
# Tomcat 마스터 프로세스의 PID를 파일로 저장
# systemd가 프로세스를 추적하는 데 사용
# -------------------------------------------------------
export CATALINA_PID="{{ tomcat_home }}/tomcat.pid"

# -------------------------------------------------------
# [CATALINA_OPTS - Tomcat 전용 JVM 옵션]
# JAVA_OPTS와 다르게 Tomcat JVM에만 적용됨 (정지 스크립트 제외)
#
# -Xms: 초기 힙 크기 (JVM 시작 시 OS에서 예약)
# -Xmx: 최대 힙 크기 (이 이상 넘어가면 OOM)
# Xms=Xmx로 설정 권장: 힙 크기 변동 없어 GC 안정적
# -------------------------------------------------------
export CATALINA_OPTS="{{ tomcat_catalina_opts }}"

# -------------------------------------------------------
# [JAVA_OPTS - 모든 Java 명령에 적용]
# Tomcat 시작 + 정지 스크립트 모두에 적용됨
# 여기에 -Xmx 설정 시 정지 스크립트에도 힙이 할당되어 메모리 낭비
# -Xmx 같은 옵션은 CATALINA_OPTS에 설정할 것
# -------------------------------------------------------
export JAVA_OPTS="-Dfile.encoding=UTF-8 -Duser.timezone=Asia/Seoul"

# -------------------------------------------------------
# [Spring Boot / 앱 관련 환경 변수]
# -------------------------------------------------------
export SPRING_PROFILES_ACTIVE="{{ environment }}"
# WAR로 배포된 Spring MVC 앱도 이 변수로 프로파일 전환 가능

# -------------------------------------------------------
# [Umask 설정]
# Tomcat이 생성하는 파일/디렉토리의 기본 권한 설정
# 0022: 파일 644 (rw-r--r--), 디렉토리 755 (rwxr-xr-x)
# 0027: 파일 640 (rw-r-----), 디렉토리 750 (rwxr-x---) - 보안 강화
# -------------------------------------------------------
umask 0022
