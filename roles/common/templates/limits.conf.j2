# =============================================================
# 시스템 리소스 제한 설정 (ulimit)
# 파일 위치: /etc/security/limits.d/90-ansible.conf
# Ansible 관리 파일 - 직접 수정 금지
#
# 형식: <도메인> <타입> <항목> <값>
#   도메인: * (모든 사용자), 특정 사용자명, @그룹명
#   타입: soft (현재 적용값, 프로세스가 hard까지 올릴 수 있음)
#         hard (절대 상한선, root만 변경 가능)
#   항목: nofile(파일수), nproc(프로세스수), stack(스택크기) 등
# =============================================================

# -------------------------------------------------------
# [파일 디스크립터 수 제한]
# Linux에서 소켓, 파이프, 일반 파일 모두 파일 디스크립터로 관리됨
# Nginx, Java 앱이 "Too many open files" 에러를 내면 여기가 원인
# 확인 명령: ulimit -n (현재 세션), /proc/PID/limits (특정 프로세스)
# -------------------------------------------------------
*    soft    nofile    {{ ulimit_nofile_soft }}
*    hard    nofile    {{ ulimit_nofile_hard }}

# root 계정은 별도로 설정 (보안상 * 에서 root가 제외되는 배포판 있음)
root soft    nofile    {{ ulimit_nofile_hard }}
root hard    nofile    {{ ulimit_nofile_hard }}

# -------------------------------------------------------
# [프로세스/스레드 수 제한]
# Java는 스레드를 프로세스처럼 관리하므로 스레드 200개 앱이면
# nproc도 200 이상이어야 함
# "Unable to create new native thread" 에러 발생 시 올려야 함
# -------------------------------------------------------
*    soft    nproc     {{ ulimit_nproc_soft }}
*    hard    nproc     {{ ulimit_nproc_hard }}
root soft    nproc     unlimited
root hard    nproc     unlimited

# -------------------------------------------------------
# [스택 크기 제한]
# 스레드 하나당 사용하는 스택 메모리 크기
# 재귀 깊은 프로그램은 stack overflow 방지를 위해 늘려야 함
# -------------------------------------------------------
*    soft    stack     8192      # 8MB (기본값과 동일)
*    hard    stack     unlimited

# -------------------------------------------------------
# [코어 덤프 설정]
# 프로세스 크래시 시 메모리 덤프를 남겨 원인 분석에 사용
# 프로덕션에서는 보통 0(비활성)으로 설정
# -------------------------------------------------------
*    soft    core      0         # 0 = 코어 덤프 비활성 (디스크 절약)
*    hard    core      unlimited # root가 필요 시 활성화할 수 있도록 상한은 열어둠

# -------------------------------------------------------
# [서비스 계정 전용 설정]
# 애플리케이션 전용 계정(appuser, nginx, mysql)은 더 높게 설정
# ※ 각 서비스 계정이 존재하는 서버에서만 실제로 적용됨
# -------------------------------------------------------
# Nginx 전용 (nginx 워커 프로세스 하나당 연결 수 × 워커 수)
nginx soft    nofile    {{ ulimit_nofile_hard }}
nginx hard    nofile    {{ ulimit_nofile_hard }}

# Spring Boot 앱 계정 전용 (HikariCP 풀 + 스레드 풀 크기를 고려)
appuser soft  nofile    {{ ulimit_nofile_hard }}
appuser hard  nofile    {{ ulimit_nofile_hard }}
appuser soft  nproc     {{ ulimit_nproc_hard }}
appuser hard  nproc     {{ ulimit_nproc_hard }}

# MariaDB 전용 (max_connections + 내부 스레드 수)
mysql soft    nofile    {{ ulimit_nofile_hard }}
mysql hard    nofile    {{ ulimit_nofile_hard }}
mysql soft    nproc     {{ ulimit_nproc_hard }}
mysql hard    nproc     {{ ulimit_nproc_hard }}
