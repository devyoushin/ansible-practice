# =============================================================
# systemd 서비스 유닛 (Ansible 관리 - 직접 수정 금지)
# 앱: {{ app_name }} | 환경: {{ environment }}
# 배포 시각: {{ ansible_date_time.iso8601 }}
# =============================================================

[Unit]
Description={{ app_name }} Spring Boot Application ({{ environment }})
# 이 서비스가 시작되려면 아래 서비스들이 먼저 실행되어야 함
After=network.target mariadb.service
# network.target: 네트워크 인터페이스 활성화 완료 후 시작
# mariadb.service: DB가 올라와야 앱 시작 가능 (DB 연결 실패로 인한 OOM 방지)
Wants=network.target
# Wants vs Requires: Wants는 실패해도 이 서비스는 시작 시도 (더 유연)

[Service]
Type=simple
# simple: ExecStart 프로세스가 메인 프로세스 (Spring Boot JAR는 이 타입)
# forking: 데몬이 fork 후 부모가 종료하는 방식 (전통적인 데몬)

User={{ app_user }}
Group={{ app_group }}
# root가 아닌 전용 계정으로 실행 (보안 필수)
# 이 계정이 없으면 배포 시 install.yml에서 생성됨

WorkingDirectory={{ app_home }}
# JAR 파일과 설정 파일이 있는 디렉토리

# -------------------------------------------------------
# [환경 변수]
# 민감한 정보(DB 비밀번호 등)는 EnvironmentFile로 분리
# EnvironmentFile={{ app_config_dir }}/.env (vault로 암호화된 값)
# -------------------------------------------------------
Environment="SPRING_PROFILES_ACTIVE={{ app_spring_profile }}"
# Spring Boot가 어떤 설정 파일을 로드할지 결정 (dev/staging/prod)
# application-prod.yml, application-dev.yml 중 선택

Environment="APP_PORT={{ app_port }}"
Environment="MANAGEMENT_PORT={{ app_management_port }}"

Environment="JAVA_OPTS={{ app_jvm_opts }}"
# JVM 힙, GC, 로그 등 모든 JVM 옵션 (defaults/main.yml의 app_jvm_opts 변수)

# -------------------------------------------------------
# [실행 명령]
# -------------------------------------------------------
ExecStart=/usr/bin/java \
  ${JAVA_OPTS} \
  -jar {{ app_jar_path }} \
  --spring.config.location={{ app_config_dir }}/application.yml \
  --server.port=${APP_PORT} \
  --management.server.port=${MANAGEMENT_PORT}

# spring.config.location: 외부 설정 파일 경로 (JAR 내부 설정보다 우선 적용)
# 민감 정보(DB 비밀번호)를 JAR 외부에서 주입할 수 있어 보안상 유리

ExecStop=/bin/kill -SIGTERM $MAINPID
# Graceful Shutdown: SIGTERM을 보내면 Spring Boot가
# 1) 새 요청 수락 중단
# 2) 처리 중인 요청 완료 대기
# 3) DB 연결 정리 후 종료
# TimeoutStopSec 시간 내 종료 안 되면 systemd가 SIGKILL 강제 종료

# -------------------------------------------------------
# [재시작 정책]
# -------------------------------------------------------
Restart=on-failure
# 비정상 종료(exit code != 0, 시그널로 종료)시만 재시작
# on-always로 설정 시 정상 종료도 재시작 (주의: 배포 중 재시작 루프 위험)

RestartSec=10
# 재시작 전 대기 시간 (초)
# 즉시 재시작은 DB 부하나 시동 실패 루프 발생 위험

StartLimitInterval=60
# 아래 StartLimitBurst 횟수 계산 기간 (60초 창)
StartLimitBurst=3
# 60초 안에 3번 이상 재시작 시도 시 서비스를 Failed 상태로 전환
# "failed" 상태는 수동으로 "systemctl reset-failed myapp" 실행 후 재시작 가능

# -------------------------------------------------------
# [종료 설정]
# -------------------------------------------------------
TimeoutStopSec=30
# SIGTERM 후 30초 기다렸다가 프로세스가 살아있으면 SIGKILL
# Spring Boot의 spring.lifecycle.timeout-per-shutdown-phase 값보다 커야 함

KillMode=mixed
# SIGTERM → 메인 프로세스 + 프로세스 그룹
# 30초 후 SIGKILL → 프로세스 그룹 전체 강제 종료
# control-group 모드와 달리 자식 프로세스도 정리됨

TimeoutStartSec=120
# 서비스 시작 타임아웃 (120초 이내에 active 상태 안 되면 failed)
# Spring Boot 최초 기동 + DB 연결 + 스키마 검증 등에 시간 필요

# -------------------------------------------------------
# [보안 강화 옵션]
# systemd의 샌드박싱 기능으로 서비스 권한을 최소화
# -------------------------------------------------------
NoNewPrivileges=yes
# 이 프로세스와 자식 프로세스가 setuid/setgid를 통해 권한 상승 불가
# 해킹 당해도 root 권한 탈취 방지

ProtectSystem=full
# /usr, /boot, /etc 를 읽기 전용으로 마운트
# 앱이 시스템 설정 파일을 수정하는 것을 OS 수준에서 차단

PrivateTmp=yes
# /tmp, /var/tmp를 프로세스 전용 임시 공간으로 격리
# 다른 프로세스가 /tmp에 남긴 파일에 접근 불가 (TMPFS race condition 방지)

ProtectHome=yes
# /root, /home 디렉토리를 읽기 전용으로 마운트
# 앱이 사용자 홈 디렉토리 파일에 접근 불가

# -------------------------------------------------------
# [로그 설정]
# StandardOutput/Error → 파일로 직접 기록
# (journald를 거치지 않아 로그 파싱이 더 쉬움)
# -------------------------------------------------------
StandardOutput=append:{{ app_log_dir }}/app.log
StandardError=append:{{ app_log_dir }}/app-error.log
# append: 파일이 이미 있으면 이어서 기록 (재시작 후에도 로그 유지)
# truncate: 재시작마다 파일 초기화 (권장 안 함)

[Install]
WantedBy=multi-user.target
# multi-user.target: 네트워크가 활성화된 일반 서버 운영 상태
# 이 설정이 있어야 systemctl enable 시 자동 시작 링크가 생성됨
