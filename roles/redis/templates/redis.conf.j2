# redis.conf — Ansible 관리 (수동 수정 금지)
# 역할: roles/redis | 호스트: {{ inventory_hostname }}
# 생성: {{ ansible_date_time.date }}

# 네트워크
bind {{ redis_bind }}
port {{ redis_port }}
tcp-backlog {{ redis_tcp_backlog }}
timeout {{ redis_timeout }}
tcp-keepalive {{ redis_tcp_keepalive }}

# 인증
{% if redis_password %}
requirepass {{ redis_password }}
{% endif %}

# 메모리
maxmemory {{ redis_maxmemory }}
maxmemory-policy {{ redis_maxmemory_policy }}
maxclients {{ redis_maxclients }}

# 영속성 (RDB)
{% if redis_save_enabled %}
{% for save_rule in redis_save_config %}
save {{ save_rule }}
{% endfor %}
{% else %}
save ""
{% endif %}

dir {{ redis_dir }}
dbfilename dump.rdb

# AOF (Append Only File)
appendonly {{ 'yes' if redis_appendonly else 'no' }}
appendfilename "appendonly.aof"
appendfsync {{ redis_appendfsync }}
no-appendfsync-on-rewrite no
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb

# 로그
loglevel {{ redis_loglevel }}
logfile {{ redis_logfile }}

# 슬로우 쿼리 로그
slowlog-log-slower-than {{ redis_slowlog_log_slower_than }}
slowlog-max-len {{ redis_slowlog_max_len }}

# 보안 강화
protected-mode yes
rename-command FLUSHALL ""
rename-command FLUSHDB  ""
rename-command DEBUG    ""
rename-command CONFIG   "CONFIG_{{ lookup('password', '/dev/null chars=hexdigits length=8') }}"
