# =============================================================
# yamllint 설정 (CI에서 YAML 문법 검사에 사용)
# 실행: yamllint .
# =============================================================

extends: default

rules:
  line-length:
    max: 160        # 기본 80에서 완화
    level: warning

  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
    check-keys: false

  comments:
    min-spaces-from-content: 1

  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

ignore: |
  .git/
  molecule/
  inventories/*/group_vars/vault.yml   # 암호화된 파일은 검사 제외
